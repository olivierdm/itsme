# ─── Me ──────────────────────────────────────────────────────────────────────

:me a odmvoc:Person, odmvoc:Student;
  odmvoc:firstName "Olivier";
  odmvoc:lastName "De Meyst";
  odmvoc:name "Olivier De Meyst";
  odmvoc:worksFor :BelgianDefence;
  odmvoc:yearOfStudy "Custom Master";
  odmvoc:enrolledIn :knowledge-graphs-2025;
  odmvoc:knows seppe:me, ward:me, thijs:me, marlin:me, dries:me, annalin:me, tiantang:me, pikajojo:me, jelle:me, kelly:me, jana:me, jule:me;
  odmvoc:interestedIn :UnmannedSystems;
  odmvoc:interestedIn :KnowledgeGraphs.

:knowledge-graphs-2025 a odmvoc:Course;
  odmvoc:name "Knowledge Graphs 2025";
  odmvoc:seeAlso <https://studiekiezer.ugent.be/studiefiche/nl/E018160/2025>.

:BelgianDefence a odmvoc:Organisation;
  odmvoc:name "Belgian Defence";
  odmvoc:legalName "Ministère de la Défense";
  odmvoc:identifier <kbopub.economie.fgov.be/kbopub/zoeknummerform.html?nummer=0308.357.159>;
  odmvoc:description "Belgian Defence is responsible for the national sovereignty of Belgium, participating in collective defense through NATO, and supporting international peace and security through EU and UN missions.";
  odmvoc:hasSubOrganization :LandForce, :AirForce, :Navy, :MedicalService, :CyberForce.

:LandForce a odmvoc:Organisation;
  odmvoc:name "Land Component".

:AirForce a odmvoc:Organisation;
  odmvoc:name "Air Component".

:Navy a odmvoc:Organisation;
  odmvoc:name "Naval Component".

:MedicalService a odmvoc:Organisation;
  odmvoc:name "Medical Component".

:CyberForce a odmvoc:Organisation;
  odmvoc:name "Cyber Command".

:UnmannedSystems a odmvoc:Topic.
:KnowledgeGraphs a odmvoc:Topic.

